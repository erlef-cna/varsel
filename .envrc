#!/usr/bin/env bash

# SPDX-License-Identifier: Apache-2.0
# SPDX-FileCopyrightText: 2026 Erlang Ecosystem Foundation

export DIRENV_WARN_TIMEOUT=20s

# devenv runs in flake mode (see flake.nix). --no-pure-eval is required so
# devenv can locate its working directory; `devenv up` still works inside.
use flake . --no-pure-eval
